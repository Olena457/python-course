
# API-key for accessing Gemini models
GOOGLE_API_KEY=your_gemini_api_key_here

# API-key for Mistral model
MISTRAL_API_KEY=your_mistral_api_key_here

# Agent Mailbox (for sending/reading emails)
AGENT_EMAIL=job.agent.demo@gmail.com

# App Password (16 characters), created in Google Account settings
GMAIL_APP_PASSWORD=your_app_password_here

# Cookies for accessing the DOU feedback form
DOU_SESSIONID=your_sessionid_cookie_here
DOU_CSRFTOKEN=your_csrftoken_cookie_here

# "Google Calendar (optional, Task 17) — NOT via .env, but separate OAuth files:  
# place `credentials.json` (OAuth Desktop) in the root; the first run will create `token.json`."
